{
  "expo": {
    "name": "SoundFree",
    "slug": "soundfree",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "soundfree",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.soundfree.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAFBFF"
      },
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-av"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "591a1994-87c5-4762-b7c5-dc0694133384"
      }
    }
  }
}
