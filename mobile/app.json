{
  "expo": {
    "name": "SoundFree",
    "slug": "soundfree",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "soundfree",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.soundfree.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAFBFF"
      },
      "usesCleartextTraffic": true,
      "permissions": [
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ]
    ]
  }
}
